{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "collection-view",
  "version": "0.1.0",
  "identifier": "com.collection-view.dev",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "osu!lazer收藏夹查看工具",
        "width": 1200,
        "height": 800,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../extractor/realm-wrappers.dll": "realm-wrappers.dll"
    },
    "externalBin": [
      "../../extractor/extractor"
    ]
  }
}