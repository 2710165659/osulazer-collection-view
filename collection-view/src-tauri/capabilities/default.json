{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "CollectionRealmExtractor",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "shell:allow-open",
    "fs:default",
    "shell:allow-execute",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "sidecar": true,
          "name": "../../extractor/extractor",
          "args": true 
        }
      ]
    }
  ]
}